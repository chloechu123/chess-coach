# --- required ---
CHESSCOM_USERNAME=your_chesscom_handle
ANTHROPIC_API_KEY=sk-ant-...

# --- engine (defaults shown) ---
STOCKFISH_PATH=/usr/games/stockfish
ANALYSIS_DEPTH=12
ENGINE_THREADS=2
ENGINE_HASH_MB=128

# --- coaching model ---
COACH_MODEL=claude-sonnet-4-6

# --- storage (optional; omit both to use local ./state JSON) ---
SUPABASE_URL=
SUPABASE_KEY=
LOCAL_STATE_DIR=./state

# --- delivery (all optional) ---
NOTION_API_KEY=
NOTION_DATABASE_ID=
SLACK_WEBHOOK_URL=
# for the interactive /coach slash command (Slack app > Basic Information > Signing Secret)
SLACK_SIGNING_SECRET=
# bot token for the /coach Events API bot (OAuth & Permissions > Bot User OAuth Token)
SLACK_BOT_TOKEN=xoxb-...

# --- behavior ---
RATED_ONLY=true

# backfill window: months back to analyze (0 or unset = full history)
BACKFILL_MONTHS=0
# restrict to time classes, comma-separated (unset = all): e.g. rapid  or  rapid,blitz
TIME_CLASSES=
